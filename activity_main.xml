<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/toolbar_bg"
        android:elevation="2dp"
        app:title="Basic Calculator"
        app:titleTextColor="@color/text_primary"
        app:titleTextAppearance="@style/TextAppearance.AppCompat.Title" />

    <!-- Display area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@color/display_background"
        android:gravity="bottom"
        android:padding="20dp">

        <!-- Expression (smaller, above) -->
        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="22sp"
            android:textColor="@color/text_secondary"
            android:gravity="end"
            android:maxLines="2"
            android:ellipsize="start"
            android:fontFamily="sans-serif-light"
            android:paddingBottom="4dp" />

        <!-- Result (large, bottom) -->
        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="52sp"
            android:textColor="@color/text_primary"
            android:gravity="end"
            android:maxLines="1"
            android:adjustViewBounds="true"
            android:fontFamily="sans-serif-light" />
    </LinearLayout>

    <!-- Button panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/background"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- Scientific row (hidden by default) -->
        <androidx.gridlayout.widget.GridLayout
            android:id="@+id/sciPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:columnCount="4"
            app:rowCount="3"
            android:layout_marginBottom="6dp">

            <!-- Row 1: φ  e  ln  log -->
            <Button android:id="@+id/btnPhi" style="@style/CalcButton.Sci"
                android:text="φ"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="0" app:layout_row="0"
                android:layout_margin="3dp"/>
            <Button android:id="@+id/btnE" style="@style/CalcButton.Sci"
                android:text="e"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="1" app:layout_row="0"
                android:layout_margin="3dp"/>
            <Button android:id="@+id/btnLn" style="@style/CalcButton.Sci"
                android:text="ln"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="2" app:layout_row="0"
                android:layout_margin="3dp"/>
            <Button android:id="@+id/btnLog" style="@style/CalcButton.Sci"
                android:text="log"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="3" app:layout_row="0"
                android:layout_margin="3dp"/>

            <!-- Row 2: sin  cos  tan  π -->
            <Button android:id="@+id/btnSin" style="@style/CalcButton.Sci"
                android:text="sin"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="0" app:layout_row="1"
                android:layout_margin="3dp"/>
            <Button android:id="@+id/btnCos" style="@style/CalcButton.Sci"
                android:text="cos"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="1" app:layout_row="1"
                android:layout_margin="3dp"/>
            <Button android:id="@+id/btnTan" style="@style/CalcButton.Sci"
                android:text="tan"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="2" app:layout_row="1"
                android:layout_margin="3dp"/>
            <Button android:id="@+id/btnPi" style="@style/CalcButton.Sci"
                android:text="π"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="3" app:layout_row="1"
                android:layout_margin="3dp"/>

            <!-- Row 3: !  ³√  √  ^ -->
            <Button android:id="@+id/btnFactorial" style="@style/CalcButton.Sci"
                android:text="!"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="0" app:layout_row="2"
                android:layout_margin="3dp"/>
            <Button android:id="@+id/btnCbrt" style="@style/CalcButton.Sci"
                android:text="³√"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="1" app:layout_row="2"
                android:layout_margin="3dp"/>
            <Button android:id="@+id/btnSqrt" style="@style/CalcButton.Sci"
                android:text="√"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="2" app:layout_row="2"
                android:layout_margin="3dp"/>
            <Button android:id="@+id/btnPow" style="@style/CalcButton.Sci"
                android:text="^"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="3" app:layout_row="2"
                android:layout_margin="3dp"/>
        </androidx.gridlayout.widget.GridLayout>

        <!-- Row 0: Scientific toggle | Rad | [spacer] | Backspace -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <Button
                android:id="@+id/btnToggleSci"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2.2"
                android:text="⇄ Scientific"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_sci_toggle"
                android:stateListAnimator="@null"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btnToggleRad"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.2"
                android:text="Rad"
                android:textSize="14sp"
                android:textColor="@color/green_accent"
                android:background="@drawable/btn_rad_toggle"
                android:stateListAnimator="@null"
                android:layout_marginEnd="6dp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.5"/>

            <Button
                android:id="@+id/btnBackspace"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="⌫"
                android:textSize="20sp"
                android:textColor="@color/white"
                android:background="@drawable/btn_backspace"
                android:stateListAnimator="@null"/>
        </LinearLayout>

        <!-- Main grid: 5 rows × 4 cols -->
        <androidx.gridlayout.widget.GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:columnCount="4"
            app:rowCount="5">

            <!-- Row 1: C  ( )  %  ÷ -->
            <Button android:id="@+id/btnClear" style="@style/CalcButton.Clear"
                android:text="C"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="0" app:layout_row="0"
                android:layout_margin="4dp"/>
            <Button android:id="@+id/btnParens" style="@style/CalcButton"
                android:text="( )"
                android:textColor="@color/green_accent"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="1" app:layout_row="0"
                android:layout_margin="4dp"/>
            <Button android:id="@+id/btnPercent" style="@style/CalcButton"
                android:text="%"
                android:textColor="@color/green_accent"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="2" app:layout_row="0"
                android:layout_margin="4dp"/>
            <Button android:id="@+id/btnDiv" style="@style/CalcButton.Operator"
                android:text="÷"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="3" app:layout_row="0"
                android:layout_margin="4dp"/>

            <!-- Row 2: 7  8  9  × -->
            <Button android:id="@+id/btn7" style="@style/CalcButton"
                android:text="7"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="0" app:layout_row="1"
                android:layout_margin="4dp"/>
            <Button android:id="@+id/btn8" style="@style/CalcButton"
                android:text="8"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="1" app:layout_row="1"
                android:layout_margin="4dp"/>
            <Button android:id="@+id/btn9" style="@style/CalcButton"
                android:text="9"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="2" app:layout_row="1"
                android:layout_margin="4dp"/>
            <Button android:id="@+id/btnMul" style="@style/CalcButton.Operator"
                android:text="×"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="3" app:layout_row="1"
                android:layout_margin="4dp"/>

            <!-- Row 3: 4  5  6  − -->
            <Button android:id="@+id/btn4" style="@style/CalcButton"
                android:text="4"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="0" app:layout_row="2"
                android:layout_margin="4dp"/>
            <Button android:id="@+id/btn5" style="@style/CalcButton"
                android:text="5"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="1" app:layout_row="2"
                android:layout_margin="4dp"/>
            <Button android:id="@+id/btn6" style="@style/CalcButton"
                android:text="6"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="2" app:layout_row="2"
                android:layout_margin="4dp"/>
            <Button android:id="@+id/btnSub" style="@style/CalcButton.Operator"
                android:text="−"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="3" app:layout_row="2"
                android:layout_margin="4dp"/>

            <!-- Row 4: 1  2  3  + -->
            <Button android:id="@+id/btn1" style="@style/CalcButton"
                android:text="1"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="0" app:layout_row="3"
                android:layout_margin="4dp"/>
            <Button android:id="@+id/btn2" style="@style/CalcButton"
                android:text="2"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="1" app:layout_row="3"
                android:layout_margin="4dp"/>
            <Button android:id="@+id/btn3" style="@style/CalcButton"
                android:text="3"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="2" app:layout_row="3"
                android:layout_margin="4dp"/>
            <Button android:id="@+id/btnAdd" style="@style/CalcButton.Operator"
                android:text="+"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="3" app:layout_row="3"
                android:layout_margin="4dp"/>

            <!-- Row 5: 00  0  .  = -->
            <Button android:id="@+id/btn00" style="@style/CalcButton"
                android:text="00"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="0" app:layout_row="4"
                android:layout_margin="4dp"/>
            <Button android:id="@+id/btn0" style="@style/CalcButton"
                android:text="0"
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="1" app:layout_row="4"
                android:layout_margin="4dp"/>
            <Button android:id="@+id/btnDot" style="@style/CalcButton"
                android:text="."
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="2" app:layout_row="4"
                android:layout_margin="4dp"/>
            <Button android:id="@+id/btnEquals" style="@style/CalcButton.Equals"
                android:text="="
                app:layout_columnWeight="1" app:layout_rowWeight="1"
                app:layout_column="3" app:layout_row="4"
                android:layout_margin="4dp"/>

        </androidx.gridlayout.widget.GridLayout>

    </LinearLayout>
</LinearLayout>
